<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Guideline để xác định vị trí bắt đầu nội dung gần giữa màn hình -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_timer_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2" />

    <!-- Danh sách các hẹn giờ đang chạy -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_active_timers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline_timer_content" />

    <!-- Giao diện nhập liệu -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_input"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_timer_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="00h 00m 00s"
            android:textColor="#FFFFFF"
            android:textSize="56sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/guideline_keyboard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_keyboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.25" />

        <GridLayout
            android:id="@+id/layout_keyboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/guideline_keyboard"
            app:layout_constraintVertical_bias="0.3">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="1"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="2"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="3"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="4"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="5"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="6"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="7"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="8"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="9"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_double_zero"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="00"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                android:text="0"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_timer"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                app:icon="@android:drawable/ic_input_delete"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp"
                app:iconTint="#FFFFFF" />

            <!-- Row 5: Nút Play ở giữa -->
            <View android:layout_width="76dp" android:layout_height="76dp" android:layout_margin="8dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_timer"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_margin="8dp"
                app:backgroundTint="#1F1F1F"
                app:cornerRadius="38dp"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="32dp"
                app:iconTint="#FFFFFF" />
            <View android:layout_width="76dp" android:layout_height="76dp" android:layout_margin="8dp" />
        </GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:visibility="gone"
        app:backgroundTint="#6200EE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>